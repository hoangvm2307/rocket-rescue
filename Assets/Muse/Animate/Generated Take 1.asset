  m_Script: {fileID: 11500000, guid: 21ebf209603e464da773338970ae700e, type: 3}
  m_Name: Generated Take 1
  m_EditorClassIdentifier: 
  m_Data: {fileID: 6463182450972520108}
  m_Preview: {fileID: -5487140490282513298}
  m_Version: 1
  m_ItemType: 0
  m_Title: Generated Take 1
  m_Description: 'A stylized combat idle animation. The character has a firm grip
    on a large, heavy rocket launcher resting on their shoulder. They maintain a
    low, wide, and stable stance with knees slightly bent. The animation loop includes
    confident, rhythmic breathing that moves the chest and shoulders, causing the
    heavy weapon to sway slightly but realistically. The character subtly shifts
    their weight from one foot to the other in an energetic, ready-for-action pose.

'
  m_Path: Assets/Muse/Animate/Generated Take 1.asset
  m_AssetName: 
  StageModel:
    m_Data:
      Version: 1
      Name: Scene
      NextEntityId: 0
      Actors:
      - m_Data:
          ID:
            m_Id:
              m_SerializedId: 0
          PrefabID: biped
          SpawnPosition: {x: 0, y: 0, z: 0}
          SpawnRotation: {x: 0, y: 0, z: 0, w: 1}
      Props: []
      CameraViewpoints:
      - m_Data:
          Pivot: {x: 0.006447715, y: 0.92368716, z: 0.18592007}
          DistanceFromPivot: 2.8903646
          Orbit: {x: 12.999995, y: 128.00005}
          ViewportOffset: {x: 0, y: 0}
    m_Identifier: Item Stage (Generated Take 1)
  m_Tooltip: '<b>Generated Take 1</b>

    A stylized combat idle animation. The
    character has a firm grip on a large, heavy rocket launcher resting on their
    shoulder. They maintain a low, wide, and stable stance with knees slightly bent.
    The animation loop includes confident, rhythmic breathing that moves the chest
    and shoulders, causing the heavy weapon to sway slightly but realistically. The
    character subtly shifts their weight from one foot to the other in an energetic,
    ready-for-action pose.

'
